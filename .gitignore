# ── Python / API ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# API secrets
api/.env
api/.env.*

# Cache files written at runtime (SQLite, JSON disk caches)
api/*.db
api/*.db-shm
api/*.db-wal
api/cache/

# ── Node / Next.js ────────────────────────────────────────────────────────────
web/node_modules/
web/.next/
web/out/
web/.vercel/
web/*.tsbuildinfo
web/next-env.d.ts

# Web secrets
web/.env
web/.env.local
web/.env.*.local

# ── API runtime data (generated at runtime, never commit) ─────────────────────
api/.cache/
api/data/*.db
api/data/*.db-shm
api/data/*.db-wal
# snapshot dumps written during dev (reliance.json, tcs.json, etc.)
api/*.json

# ── Claude Code internal ───────────────────────────────────────────────────────
.claude/

# ── Dev screenshots ───────────────────────────────────────────────────────────
screenshot_*.png

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/settings.json

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
